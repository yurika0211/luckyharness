# ============================================================
# LuckyHarness 环境变量配置
# 复制此文件为 .env 并填入实际值: cp .env.example .env
# ============================================================

# ----- LLM Provider -----
# 提供商: openai | anthropic | ollama | openrouter
LH_PROVIDER=openai

# API Key（必填，ollama 可留空）
LH_API_KEY=sk-your-api-key-here

# API Base URL（可选，用于兼容 OpenAI 格式的第三方服务）
# LH_API_BASE=https://api.openai.com/v1

# 模型名称
LH_MODEL=gpt-4o

# 最大上下文 token 数
LH_MAX_TOKENS=131072

# 温度 (0.0 - 2.0)
LH_TEMPERATURE=0.7

# ----- Telegram Bot -----
# 启用 Telegram 网关时必填
LH_TELEGRAM_TOKEN=

# 允许的 Chat ID 白名单（逗号分隔，留空允许所有）
# LH_TELEGRAM_ALLOWED_CHATS=

# 管理员 User ID（逗号分隔）
# LH_TELEGRAM_ADMIN_IDS=

# ----- HTTP API Server -----
# 监听地址
LH_API_ADDR=:9090

# API Key 白名单（逗号分隔，留空不鉴权）
# LH_API_KEYS=

# 速率限制（每分钟请求数）
LH_RATE_LIMIT=60

# ----- SOUL 人格 -----
# 自定义 SOUL.md 路径（留空使用默认）
# LH_SOUL_PATH=/etc/luckyharness/SOUL.md

# ----- 数据目录 -----
# 配置与持久化目录
LH_HOME=/var/lib/luckyharness

# ----- 日志 -----
# 日志级别: debug | info | warn | error
LH_LOG_LEVEL=info

# 日志格式: json | text
LH_LOG_FORMAT=json

# ----- Fallback 降级链（可选）-----
# 降级链 JSON，格式:
# [{"provider":"anthropic","api_key":"sk-ant-xxx","model":"claude-sonnet-4-20250514"}]
# LH_FALLBACKS=

# ----- Web 搜索 (v0.37.0) -----
# 搜索 provider: brave | ddgs | searxng（默认 brave，无 key 自动降级 ddgs）
LH_WEB_SEARCH_PROVIDER=brave
# Brave Search API key（https://brave.com/search/api/）
# LH_WEB_SEARCH_API_KEY=
# SearXNG 自部署地址（provider=searxng 时必填）
# LH_WEB_SEARCH_BASE_URL=
# 最大结果数（默认 5）
LH_WEB_SEARCH_MAX_RESULTS=5
# HTTP/SOCKS5 代理
# LH_WEB_SEARCH_PROXY=

# Jina Reader API key（web_fetch 用，免费额度无需 key）
# JINA_API_KEY=